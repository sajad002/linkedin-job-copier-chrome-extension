{
  "manifest_version": 3,
  "name": "LinkedIn Job Copier",
  "version": "1.0.0",
  "description": "Copy LinkedIn job result lists and open job details for GPT analysis.",
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "host_permissions": ["https://www.linkedin.com/jobs/*"],
  "action": {
    "default_title": "Copy LinkedIn Jobs",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
