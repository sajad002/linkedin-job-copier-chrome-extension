{
  "manifest_version": 3,
  "name": "LinkedIn Job Copier",
  "version": "1.3.2",
  "description": "Copy LinkedIn job result lists, expanded open job details, directory-safe open-job names, and dismiss visible LinkedIn job cards.",
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite",
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/jobs/*"
  ],
  "action": {
    "default_title": "Copy LinkedIn Jobs",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
